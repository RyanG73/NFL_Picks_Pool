{
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/api/static/$1" },
    { "src": "/(.*)", "dest": "/api/main.py" }
  ],
  "crons": [
    {
      "path": "/api/cron/lock-and-reveal",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/detect-cancellations",
      "schedule": "0 * * * *"
    }
  ]
}
